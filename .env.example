# Public DNS names pointing to this Docker host
NOVELLA_HOST=novella.example.com
AUTHENTIK_HOST=auth.example.com

# Used by Let's Encrypt for certificate notices
ACME_EMAIL=you@example.com

# Generate with: openssl rand -base64 36 | tr -d '\n'
PG_PASS=replace-with-a-random-postgres-password

# Generate with: openssl rand -base64 60 | tr -d '\n'
AUTHENTIK_SECRET_KEY=replace-with-a-random-authentik-secret

# Pinned so upgrades are deliberate
AUTHENTIK_TAG=2026.5.3
AUTHENTIK_LOG_LEVEL=info

# Optional scene narration. Keep the API key only in .env on the server.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# false requests zero-retention mode from ElevenLabs.
ELEVENLABS_ENABLE_LOGGING=false
